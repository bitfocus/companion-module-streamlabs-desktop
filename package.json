{
	"name": "companion-module-streamlabs-desktop",
	"version": "1.0.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"test": "vitest run",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-streamlabs-desktop.git"
	},
	"bugs": {
		"url": "https://github.com/bitfocus/companion-module-streamlabs-desktop/issues"
	},
	"homepage": "https://github.com/bitfocus/companion-module-streamlabs-desktop#readme",
	"engines": {
		"node": ">=22.20",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "2.1.2",
		"sockjs-client": "^1.6.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.1",
		"@types/node": "^26.1.1",
		"@types/sockjs-client": "^1.5.4",
		"eslint": "^10.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.5",
		"rimraf": "^6.1.3",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^4.1.10"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.17.0"
}
